{
  "name": "siya",
  "version": "1.0.0",
  "description": "Minimal toast notification library",
  "type": "module",

  "main": "./dist/index.global.js",
  "module": "./dist/siya.js",
  "types": "./dist/index.d.ts",

  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly"
  },

  "keywords": [
    "toast",
    "notification",
    "ui",
    "cdn",
    "typescript"
  ],

  "license": "MIT",

  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}